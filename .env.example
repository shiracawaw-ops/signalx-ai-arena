# ─── SignalX AI Arena — Environment Variables ────────────────────────────────
# Copy this file to .env and fill in the values you need.
# NEVER commit .env to version control.

# ── API Server ────────────────────────────────────────────────────────────────

# Port the Express API server listens on.
# REQUIRED — server will not start without this.
PORT=8080

# Node environment — affects logging verbosity and error formatting.
# Values: development | production
NODE_ENV=development

# Session secret — used to sign session cookies when a session middleware is
# added. Not currently enforced on startup; set a strong value before deploying.
SESSION_SECRET=replace_with_a_long_random_string

# Pino log level — controls log verbosity.
# Values: trace | debug | info | warn | error | fatal  (default: info)
LOG_LEVEL=info

# ── Frontend (Vite build) ─────────────────────────────────────────────────────

# Base URL path for the Vite frontend build.
# REQUIRED for `pnpm --filter @workspace/signalx-arena run build`.
# In the Replit dev server this is set automatically; for a local dev start
# you must set it (e.g. "/" for serving at root).
BASE_PATH=/

# ── Electron (desktop build only) ────────────────────────────────────────────

# NOTE: The Electron main process currently hardcodes the embedded API port
# to 18080 (see electron/main.js). The variable below is provided for
# documentation purposes; changing it here has no effect without also updating
# electron/main.js.
# ELECTRON_API_PORT=18080

# ── Exchange API Keys (optional — entered at runtime via the UI) ─────────────
# API keys are passed per-request from the frontend and are NOT stored
# server-side. The stubs below are only for reference.

# BINANCE_API_KEY=
# BINANCE_SECRET_KEY=

# BYBIT_API_KEY=
# BYBIT_SECRET_KEY=

# OKX_API_KEY=
# OKX_SECRET_KEY=
# OKX_PASSPHRASE=

# KUCOIN_API_KEY=
# KUCOIN_SECRET_KEY=
# KUCOIN_PASSPHRASE=

# COINBASE_API_KEY=
# COINBASE_SECRET_KEY=

# DERIBIT_CLIENT_ID=
# DERIBIT_CLIENT_SECRET=
