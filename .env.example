# ─── SignalX AI Arena — Environment Variables ────────────────────────────────
# Copy this file to .env and fill in the values you need.
# NEVER commit .env to version control.

# ── API Server ────────────────────────────────────────────────────────────────

# Port the Express API server listens on (default: 8080 in dev, 18080 in Electron)
PORT=8080

# Node environment — affects logging verbosity and error handling
# Values: development | production
NODE_ENV=development

# Session secret — required at runtime to sign session cookies
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace_with_a_long_random_string

# ── Electron (desktop build only) ────────────────────────────────────────────

# Port the embedded API server uses when running inside the Electron shell
# Overrides PORT when the app is packaged as a desktop app
ELECTRON_API_PORT=18080

# ── Exchange API Keys (optional — entered at runtime via the UI) ─────────────
# API keys are passed per-request from the frontend and are NEVER stored
# server-side. The variables below are only needed if you want to pre-populate
# a server-side environment (not the normal use case).

# BINANCE_API_KEY=
# BINANCE_SECRET_KEY=

# BYBIT_API_KEY=
# BYBIT_SECRET_KEY=

# OKX_API_KEY=
# OKX_SECRET_KEY=
# OKX_PASSPHRASE=

# KUCOIN_API_KEY=
# KUCOIN_SECRET_KEY=
# KUCOIN_PASSPHRASE=

# COINBASE_API_KEY=
# COINBASE_SECRET_KEY=

# DERIBIT_CLIENT_ID=
# DERIBIT_CLIENT_SECRET=
